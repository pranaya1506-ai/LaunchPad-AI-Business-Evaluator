import os

# Create the folder structure
os.makedirs("templates", exist_ok=True)

# Define the visual appearance of your LaunchPad app
html_layout = """
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>LaunchPad AI - Idea Evaluator</title>
    <style>
        body { font-family: Arial, sans-serif; max-width: 650px; margin: 40px auto; padding: 20px; background-color: #f8f9fa; }
        .box { background: white; padding: 25px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        h2 { color: #007bff; margin-top: 0; }
        textarea { width: 100%; height: 130px; padding: 10px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box; }
        button { background-color: #007bff; color: white; border: none; padding: 12px 20px; width: 100%; font-size: 16px; border-radius: 4px; cursor: pointer; margin-top: 10px; }
        button:hover { background-color: #0056b3; }
        #result { margin-top: 20px; display: none; background: #e9ecef; padding: 15px; border-left: 5px solid #007bff; border-radius: 4px; white-space: pre-wrap; line-height: 1.5; }
    </style>
</head>
<body>
    <div class="box">
        <h2>LaunchPad AI: Smart Business Idea Evaluator</h2>
        <p>Type your business concept below to get a complete target market analysis and viability score.</p>
        <form id="evalForm">
            <textarea id="ideaText" placeholder="Describe your startup idea (e.g., LocalHire platform details)..." required></textarea>
            <button type="submit">Evaluate Idea</button>
        </form>
        <div id="result"></div>
    </div>

    <script>
        document.getElementById('evalForm').onsubmit = async (e) => {
            e.preventDefault();
            const concept = document.getElementById('ideaText').value;
            const resultDiv = document.getElementById('result');
            resultDiv.style.display = 'block';
            resultDiv.innerText = 'Analyzing idea viability via Gemini... Please wait...';

            try {
                const response = await fetch('/evaluate', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: 'idea=' + encodeURIComponent(concept)
                });
                const data = await response.json();
                resultDiv.innerText = data.evaluation;
            } catch (err) {
                resultDiv.innerText = "Error: Background server thread disconnected.";
            }
        };
    </script>
</body>
</html>
"""

# Write the layout into the templates folder
with open("templates/index.html", "w", encoding="utf-8") as f:
    f.write(html_layout)

print("Visual interface file written successfully to templates/index.html!")
